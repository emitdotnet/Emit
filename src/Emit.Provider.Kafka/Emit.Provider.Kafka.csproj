<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Emit.Provider.Kafka</RootNamespace>
    <AssemblyName>Emit.Provider.Kafka</AssemblyName>
    <PackageId>Emit.Provider.Kafka</PackageId>
    <Description>Kafka outbox provider for Emit. Enables reliable Kafka message production through the transactional outbox pattern.</Description>
    <PackageTags>outbox;transactional;kafka;messaging;reliability</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Emit\Emit.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Confluent.Kafka" />
    <PackageReference Include="Confluent.SchemaRegistry" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Emit.Tests" />
    <InternalsVisibleTo Include="Emit.IntegrationTests" />
    <!-- Required for Moq to create proxies for internal types -->
    <InternalsVisibleTo Include="DynamicProxyGenAssembly2, " />
  </ItemGroup>

</Project>
